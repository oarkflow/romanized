{
	"name": "romanized-workspace",
	"private": true,
	"version": "1.0.1",
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter solid-demo dev",
		"dev:basic": "pnpm --filter basic-demo dev",
		"dev:react": "pnpm --filter react-demo dev",
		"dev:solid": "pnpm --filter solid-demo dev",
		"build": "pnpm -r --filter './packages/*' build",
		"test:core": "pnpm --filter @oarkflow/nepali-input test",
		"build:demo": "pnpm --filter solid-demo build",
		"build:demo:basic": "pnpm --filter basic-demo build",
		"build:demo:react": "pnpm --filter react-demo build",
		"build:demo:solid": "pnpm --filter solid-demo build",
		"preview": "pnpm --filter solid-demo preview",
		"preview:basic": "pnpm --filter basic-demo preview",
		"preview:react": "pnpm --filter react-demo preview",
		"preview:solid": "pnpm --filter solid-demo preview",
		"clean": "pnpm -r exec rm -rf dist node_modules",
		"publish:all": "pnpm -r --filter './packages/*' publish --access public"
	},
	"devDependencies": {
		"typescript": "~5.9.3",
		"vite": "^7.2.4"
	}
}
