{
	"name": "@oarkflow/nepali-input",
	"private": true,
	"version": "1.0.1",
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter demo dev",
		"build": "pnpm -r --filter './packages/*' build",
		"build:demo": "pnpm --filter demo build",
		"preview": "pnpm --filter demo preview",
		"clean": "pnpm -r exec rm -rf dist node_modules",
		"publish:all": "pnpm -r --filter './packages/*' publish --access public"
	},
	"devDependencies": {
		"typescript": "~5.9.3",
		"vite": "^7.2.4"
	}
}
