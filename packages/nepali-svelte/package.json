{
	"name": "@verishore/nepali-svelte",
	"version": "1.0.0",
	"description": "Svelte components for Nepali input with instant romanized-to-Devanagari transliteration",
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "svelte-package -i src -o dist",
		"dev": "svelte-package -i src -o dist --watch",
		"type-check": "svelte-check"
	},
	"keywords": [
		"nepali",
		"devanagari",
		"transliteration",
		"svelte",
		"input",
		"component"
	],
	"author": "Verishore",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/verishore/nepali-input.git",
		"directory": "packages/nepali-svelte"
	},
	"peerDependencies": {
		"svelte": "^4.0.0 || ^5.0.0"
	},
	"dependencies": {
		"@verishore/nepali-input": "workspace:*"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.3.7",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"svelte": "^5.18.3",
		"svelte-check": "^4.1.1",
		"typescript": "~5.9.3",
		"vite": "^7.2.4"
	}
}
