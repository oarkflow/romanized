{
	"name": "@oarkflow/nepali-react",
	"version": "1.0.0",
	"description": "React components for Nepali input with instant romanized-to-Devanagari transliteration",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsc && vite build",
		"dev": "vite build --watch",
		"type-check": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"nepali",
		"devanagari",
		"transliteration",
		"react",
		"input",
		"component"
	],
	"author": "Oarkflow",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/oarkflow/romanized.git",
		"directory": "packages/nepali-react"
	},
	"peerDependencies": {
		"react": ">=16.8.0"
	},
	"dependencies": {
		"@oarkflow/nepali-input": "workspace:*"
	},
	"devDependencies": {
		"@types/react": "^18.3.18",
		"react": "^18.3.1",
		"typescript": "~5.9.3",
		"vite": "^7.2.4",
		"vite-plugin-dts": "^4.3.0"
	}
}
